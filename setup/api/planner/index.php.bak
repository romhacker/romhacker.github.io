<?php
session_start();

header('Content-Type: application/json; charset=utf-8');

$objectId = isset($_GET['object_id']) ? (string)$_GET['object_id'] : '';
$planId   = isset($_GET['plan_id']) ? (string)$_GET['plan_id'] : '';

/*
 * Если после import+reload фронт запрашивает object_id=0,
 * подсовываем только что импортированный проект из сессии.
 */
if (($objectId === '' || $objectId === '0') && !empty($_SESSION['last_imported_plan_data'])) {
    echo json_encode(array(
        'object_id' => isset($_SESSION['last_imported_object_id']) ? (string)$_SESSION['last_imported_object_id'] : '0',
        'visitor_id' => isset($_SESSION['session']) ? (string)$_SESSION['session'] : session_id(),
        'session_id' => isset($_SESSION['session']) ? (string)$_SESSION['session'] : session_id(),
        'client_id' => '941524',
        'object_save_id' => '37',
        'save_id' => '19',
        'plan_id' => isset($_SESSION['last_imported_plan_id']) ? $_SESSION['last_imported_plan_id'] : '',
        'floor_id' => isset($_SESSION['last_imported_floor_id']) ? (string)$_SESSION['last_imported_floor_id'] : '',
        'data' => $_SESSION['last_imported_plan_data'],
        'chat_new_messages' => 0,
        'direct' => array(
            'id' => '3',
            'plan' => 'init',
            'html' => ''
        ),
		'floors' => isset($_SESSION['last_imported_floors_list']) 
			? $_SESSION['last_imported_floors_list'] 
			: array('prev' => array(), 'next' => array()),
        'units' => 'cm'
    ));
    exit;
}

/*
 * Во всех остальных случаях отдаём ваш исходный planner/index.html как есть.
 * Это не ломает обычную загрузку.
 */
$indexHtml = __DIR__ . DIRECTORY_SEPARATOR . 'index.html';

if (file_exists($indexHtml)) {
    readfile($indexHtml);
    exit;
}

echo json_encode(array(
    'result' => 'error',
    'message' => 'planner/index.html not found'
));
exit;
?>